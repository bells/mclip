{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mclip",
  "version": "0.1.0",
  "identifier": "com.watson.mclip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "mclip",
        "width": 300,
        "height": 200,
        "minWidth": 300,
        "minHeight": 100,
        "maxWidth": 300,
        "maxHeight": 600,
        "resizable": true,
        "decorations": false,    
        "transparent": true,     
        "alwaysOnTop": true,     
        "visible": false,        
        "skipTaskbar": true   
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
